/*Un primo ﬁle (il cui nome venga richiesto all'utente) contiene una matrice di
dimensione NxM corrispondente a una zona marina e ogni elemento (valore ﬂoating
point) corrisponde alla temperatura media del mese di agosto di una porzione di quella
zona valutata nell'agosto 2021. Un secondo ﬁle (il cui nome venga richiesto all'utente)
contiene le temperature della stessa zona relative all'anno 2022.
Si suppone che ci sia stato un cambiamento climatico signiﬁcativo di quella zona se
almeno il 70% delle celle corrispondenti delle due matrici hanno avuto un incremento
di valore di almeno un grado.

Si scriva un programma C89 che veriﬁchi se questo cambiamento c'è stato scrivendo a
video "Temperatura aumentata" oppure scrivendo "Temperatura non aumentata". Si crei
una terza matrice di interi che per ogni cella corrispondente nelle altre due matrici
scriva 1 se la temperatura è aumentata di almeno un grado, -1 se è diminuita di almeno
un grado e 0 negli altri casi.*/

#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#define R 3
#define C 4
#define N 200

int main() {
int i,j, count;
float m21[R][C];
float m22[R][C];
int matrice [R][C];
char nomefile1[50];
char nomefile2[50];
FILE *fp1, *fp2;
float soglia, diff;

printf("Inserisci il nome del file:");
scanf("%s", nomefile1);
fp1 = fopen(nomefile1,"r");
if(fp1 == NULL){
    printf("ERRORE: file non trovato.\n");
    return -1;
}
printf("Aperto file %s\n", nomefile1);

for(i = 0; i<R;i++){
    for(j = 0; j<C;j++){
     fscanf(fp1, "%f",&m21[i][j]);

    }
}
fclose(fp1);

printf("Inserisci il nome del secondo file:");
scanf("%s",nomefile2);

fp2 = fopen(nomefile2,"r");

if(fp2 == NULL){
    printf("ERRORE: impossibile aprire il file %s\n", nomefile2);
    return -1;
}

for(i = 0; i< R;i++){
    for(j = 0; j<C;j++){
        fscanf(fp2,"%f", &m22[i][j]);
    }
}
fclose(fp2);

count = 0;

for(i = 0; i<R;i++){

    for(j = 0; j<C;j++){
        diff = m22[i][j] - m21[i][j];

        if(m22[i][j] >= 1.0){
            matrice[i][j] = 1;
            count++;
        }
        if(diff <= -1.0){
            matrice[i][j] = -1;
            count++;
        }
        else{
            matrice[i][j] = 0;
        }

        }
    }

soglia = (R*C * 70 + 99) / 100
if(count >= soglia){
    printf("Temperatura aumentata.\n");

} else {
    printf("Temperatura non aumentata.\n");
}





return 0;
}
